#!/usr/bin/env bash
# bin/her — Lightweight CLI wrapper for the her background daemon.
#
# Usage: her {start|stop|status|logs|restart|install|uninstall}
#
# Targets:
#   start      Start daemon directly (respects direnv / shell env vars)
#   stop       Send SIGTERM via pidfile; wait for clean exit
#   status     Show running PID and uptime
#   logs       Tail live log (Ctrl-C to stop)
#   restart    stop → start
#   install    Install launchd agent (auto-start on login)
#   uninstall  Remove launchd agent
#
# 환경변수 안내:
#   GEMINI_API_KEY 는 launchd 에서 direnv 를 실행하지 않으므로 자동으로 주입되지
#   않습니다. launchd 설치 후 키가 보이지 않으면 ~/.her/env 파일에 export 한 뒤
#   plist 의 EnvironmentVariables 에 추가하거나, bin/her start 로 직접 실행하세요.
#   ※ Wake word 는 로컬 Whisper 를 사용하므로 별도 API 키 불필요.

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
HER_HOME="${HER_HOME:-$HOME/.her}"
HER_LOG_DIR="${HER_LOG_DIR:-$HER_HOME/logs}"
HER_LOG="$HER_LOG_DIR/her.log"
HER_PID="$HER_HOME/her.pid"
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PLIST_NAME="com.her.assistant.plist"
PLIST_TEMPLATE="$PROJECT_DIR/infra/launchd/$PLIST_NAME.template"
PLIST_DEST="$HOME/Library/LaunchAgents/$PLIST_NAME"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_pid_running() {
    # Returns 0 (true) and prints PID if pidfile contains a live process.
    [[ -f "$HER_PID" ]] || return 1
    local pid
    pid="$(cat "$HER_PID" 2>/dev/null)" || return 1
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    echo "$pid"
}

_require_stopped() {
    local pid
    if pid="$(_pid_running 2>/dev/null)"; then
        echo "오류: her 데몬이 이미 실행 중이에요 (pid $pid). 먼저 'bin/her stop' 을 실행하세요." >&2
        exit 1
    fi
}

_ensure_dirs() {
    mkdir -p "$HER_HOME/logs"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_start() {
    _require_stopped
    _ensure_dirs
    echo "her 데몬을 시작합니다..."
    # Run daemon in background; nohup ensures it survives terminal close.
    # Shell env vars (GEMINI_API_KEY etc.) are inherited from current session.
    nohup uv run --directory "$PROJECT_DIR" \
        python -m apps.daemon \
        --db "$PROJECT_DIR/data/db.sqlite" \
        --log-dir "$HER_LOG_DIR" \
        >> "$HER_LOG_DIR/her.stdout.log" 2>> "$HER_LOG_DIR/her.stderr.log" &
    local bg_pid=$!
    # Give the process a moment to write its pidfile
    local waited=0
    while [[ $waited -lt 30 ]]; do
        if _pid_running >/dev/null 2>&1; then
            echo "her 데몬이 시작되었어요 (pid $(cat "$HER_PID"))."
            echo "로그: bin/her logs"
            return 0
        fi
        sleep 0.2
        waited=$((waited + 1))
    done
    echo "경고: 데몬이 ${waited}×0.2s 이내에 pidfile 을 생성하지 않았습니다. 로그를 확인하세요."
    echo "  bin/her logs"
}

cmd_stop() {
    local pid
    if ! pid="$(_pid_running 2>/dev/null)"; then
        echo "her 데몬이 실행 중이 아니에요."
        return 0
    fi
    echo "Stopping her daemon (pid $pid)..."
    kill -TERM "$pid" 2>/dev/null || true
    # Wait up to 10 s for clean exit
    local waited=0
    while kill -0 "$pid" 2>/dev/null && [[ $waited -lt 50 ]]; do
        sleep 0.2
        waited=$((waited + 1))
    done
    if kill -0 "$pid" 2>/dev/null; then
        echo "경고: 데몬이 종료되지 않아 강제 종료합니다 (SIGKILL)..."
        kill -KILL "$pid" 2>/dev/null || true
    fi
    rm -f "$HER_PID"
    echo "her 데몬이 종료되었어요."
}

cmd_status() {
    local pid
    if ! pid="$(_pid_running 2>/dev/null)"; then
        echo "her 데몬이 실행 중이 아니에요."
        return 0
    fi
    # Try to get start time for uptime display (macOS ps)
    local started
    started="$(ps -o lstart= -p "$pid" 2>/dev/null | xargs || echo "unknown")"
    echo "her daemon is running — pid $pid, started: $started"
    echo "Log: $HER_LOG"
}

cmd_logs() {
    _ensure_dirs
    if [[ ! -f "$HER_LOG" ]]; then
        echo "로그 파일이 아직 없어요: $HER_LOG"
        return 0
    fi
    tail -f "$HER_LOG"
}

cmd_restart() {
    cmd_stop
    sleep 0.5
    cmd_start
}

cmd_install() {
    if [[ ! -f "$PLIST_TEMPLATE" ]]; then
        echo "오류: plist 템플릿을 찾을 수 없어요: $PLIST_TEMPLATE" >&2
        exit 1
    fi
    _ensure_dirs
    mkdir -p "$HOME/Library/LaunchAgents"
    sed "s|__PROJECT__|$PROJECT_DIR|g; s|__HOME__|$HOME|g" \
        "$PLIST_TEMPLATE" > "$PLIST_DEST"
    launchctl load -w "$PLIST_DEST"
    echo "launchd 에이전트가 설치되었어요: $PLIST_DEST"
    echo ""
    echo "⚠️  환경변수 안내:"
    echo "   direnv 환경 변수가 launchd 에서 보이지 않으면,"
    echo "   ~/.her/env 파일에 export 후 plist 의 EnvironmentVariables 에 추가하거나"
    echo "   bin/her start 로 부팅하세요."
    echo ""
    echo "   예: echo 'export GEMINI_API_KEY=sk-...' >> ~/.her/env"
}

cmd_uninstall() {
    launchctl unload -w "$PLIST_DEST" 2>/dev/null || true
    rm -f "$PLIST_DEST"
    echo "launchd 에이전트가 제거되었어요."
}

# ---------------------------------------------------------------------------
# Consolidator commands
# ---------------------------------------------------------------------------

CONSOLIDATOR_PLIST_NAME="com.her.consolidator.plist"
CONSOLIDATOR_PLIST_TEMPLATE="$PROJECT_DIR/infra/launchd/$CONSOLIDATOR_PLIST_NAME.template"
CONSOLIDATOR_PLIST_DEST="$HOME/Library/LaunchAgents/$CONSOLIDATOR_PLIST_NAME"

cmd_consolidator_install() {
    if [[ ! -f "$CONSOLIDATOR_PLIST_TEMPLATE" ]]; then
        echo "오류: plist 템플릿을 찾을 수 없어요: $CONSOLIDATOR_PLIST_TEMPLATE" >&2
        exit 1
    fi
    _ensure_dirs
    mkdir -p "$HOME/Library/LaunchAgents"
    sed "s|__PROJECT__|$PROJECT_DIR|g; s|__HOME__|$HOME|g" \
        "$CONSOLIDATOR_PLIST_TEMPLATE" > "$CONSOLIDATOR_PLIST_DEST"
    launchctl load -w "$CONSOLIDATOR_PLIST_DEST"
    echo "Consolidator launchd 에이전트가 설치되었어요: $CONSOLIDATOR_PLIST_DEST"
    echo ""
    echo "  매일 03:00 에 자동 실행됩니다."
    echo "  수동 실행: make consolidate"
    echo ""
    echo "⚠️  환경변수 안내:"
    echo "   GEMINI_API_KEY 는 launchd 에서 자동 주입되지 않습니다."
    echo "   plist 의 EnvironmentVariables 에 직접 추가하거나"
    echo "   make consolidate 로 직접 실행하세요."
}

cmd_consolidator_uninstall() {
    launchctl unload -w "$CONSOLIDATOR_PLIST_DEST" 2>/dev/null || true
    rm -f "$CONSOLIDATOR_PLIST_DEST"
    echo "Consolidator launchd 에이전트가 제거되었어요."
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

_usage() {
    cat >&2 <<'EOF'
Usage: her <command>

Commands:
  start                  Start the her daemon (inherits current shell env vars)
  stop                   Stop the her daemon gracefully
  status                 Show daemon status and PID
  logs                   Tail the live log (Ctrl-C to quit)
  restart                stop + start
  install                Install launchd agent (auto-start on login)
  uninstall              Remove launchd agent
  consolidator-install   Install consolidator launchd agent (daily 03:00)
  consolidator-uninstall Remove consolidator launchd agent

환경변수 안내: GEMINI_API_KEY 는 launchd 에서 자동 주입되지 않습니다.
상세 내용은 infra/launchd/ 아래 각 .plist.template 헤더 주석을 참고.
Wake word 는 로컬 Whisper 사용 — 별도 키 불필요.
EOF
    exit 1
}

case "${1:-}" in
    start)                   cmd_start                   ;;
    stop)                    cmd_stop                    ;;
    status)                  cmd_status                  ;;
    logs)                    cmd_logs                    ;;
    restart)                 cmd_restart                 ;;
    install)                 cmd_install                 ;;
    uninstall)               cmd_uninstall               ;;
    consolidator-install)    cmd_consolidator_install    ;;
    consolidator-uninstall)  cmd_consolidator_uninstall  ;;
    *)                       _usage                      ;;
esac
