# .envrc.example — direnv config template for the `her` project
#
# Usage:
#   1)  cp .envrc.example .envrc
#   2)  edit .envrc and replace REPLACE_ME with your real key
#   3)  direnv allow
#
# IMPORTANT:
#   - .envrc must stay gitignored — never commit real keys.
#   - This .envrc.example is committed and stays as a template.

# ── Required ──────────────────────────────────────────────────────────
# Google AI Studio → API keys → create.
#   https://aistudio.google.com/apikey
# Used for:
#   - gemini-3.1-pro-preview   (main chat reasoning)
#   - gemini-2.5-flash         (Consolidator / batch)
#   - gemini-embedding-001     (memory embeddings, 768d)
export GEMINI_API_KEY="REPLACE_ME"

# ── Optional knobs ────────────────────────────────────────────────────
# export HER_DB_PATH="${PWD}/data/db.sqlite"
# export HER_AGENT_MODEL="gemini-3.1-pro-preview"
# export HER_WEB_PORT="8765"

# ── Optional: Stocks widget ───────────────────────────────────────────
# Used by the stocks widget. Each provider is independent — set only
# the ones you actually use.
#
# Finnhub (global, free real-time tier)         https://finnhub.io
# export FINNHUB_API_KEY="REPLACE_ME"
#
# Polygon (US stocks, fallback / pro features)  https://polygon.io
# export POLYGON_API_KEY="REPLACE_ME"
#
# Kiwoom REST API (KOSPI/KOSDAQ).              https://www.kiwoom.com
#   APP_KEY  = REST API "App Key"
#   SECRET   = REST API "App Secret"
#   BASE_URL = api.kiwoom.com (real) or mockapi.kiwoom.com (sandbox)
# export KIWOOM_APP_KEY="REPLACE_ME"
# export KIWOOM_APP_SECRET="REPLACE_ME"
# export KIWOOM_BASE_URL="https://api.kiwoom.com"

# ── Optional: News widget + chat news intent ──────────────────────────
# Tavily web/news search.                       https://tavily.com
# Used by the 주식 뉴스 widget AND by the agent when the user message
# looks news-seeking ("뉴스", "최근 동향", etc.).
# export TAVILY_API_KEY="REPLACE_ME"
